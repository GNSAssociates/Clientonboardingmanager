# ──────────────────────────────────────────────────────────────
# GNS Onboarding Platform — environment template
# Copy to .env.local (app) / .env (db tooling) and fill in.
# All infra is EU/UK region (NFR-PRIV-1). Never commit real secrets.
# ──────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
APP_URL=http://localhost:3000
LOG_LEVEL=info

# Supabase (EU region project)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres (Drizzle migrations / server) — Supabase EU connection string
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Auth — Microsoft Entra ID (staff SSO)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# AI — Anthropic Claude (direct API, EU DPA, no-training)
ANTHROPIC_API_KEY=
AI_MODEL_COMPLEX=claude-opus-4-8
AI_MODEL_FAST=claude-haiku-4-5

# Microsoft Graph (mail) + SMTP fallback
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Companies House
COMPANIES_HOUSE_API_KEY=

# Accounting integrations
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=

# KYC/AML (default: Amiqus) + E-sign (default: Dropbox Sign)
KYC_PROVIDER=amiqus
KYC_API_KEY=
ESIGN_PROVIDER=dropbox_sign
ESIGN_API_KEY=

# Document AI / OCR (default: Azure Document Intelligence, EU)
AZURE_DOCAI_ENDPOINT=
AZURE_DOCAI_KEY=

# Observability (optional — error reporting activates when set)
SENTRY_DSN=

# Webhook signing (HMAC) for app <-> n8n and inbound provider webhooks
WEBHOOK_SIGNING_SECRET=change-me-in-prod
