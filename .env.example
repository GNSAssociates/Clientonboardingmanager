# ──────────────────────────────────────────────────────────────
# GNS Compliance Manager — environment template
# Copy to .env.local (app) / .env (db tooling) and fill in.
# All infra is EU/UK region (NFR-PRIV-1). Never commit real secrets.
# ──────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
LOG_LEVEL=info

# Supabase (EU region project)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres (Drizzle migrations / server) — Supabase EU connection string
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Authentication ────────────────────────────────────────────
# Auth cookie signing secret (REQUIRED in production)
AUTH_SHIM_SECRET=change-me-in-prod

# Admin account — seeded on first boot
ADMIN_EMAIL=accounts@gnsassociates.co.uk
ADMIN_PASSWORD=changeme

# Auth — Microsoft Entra ID (staff SSO, optional)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# ── Email (SMTP / API providers) ─────────────────────────────
# SMTP2GO (recommended — works behind blocked SMTP ports)
SMTP2GO_API_KEY=
SMTP2GO_FROM_EMAIL=

# SMTP direct (fallback)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# Brevo (Sendinblue) — another HTTP API fallback
BREVO_API_KEY=
BREVO_FROM_EMAIL=

# Resend — another HTTP API fallback
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Email display settings
MAIL_FROM_NAME=GNS Associates
MAIL_FROM_EMAIL=info@gnsassociates.co.uk
MAIL_CC=enquiries@gnsassociates.co.uk
MAIL_PROVIDER_ORDER=smtp2go,smtp,brevo,resend

# Microsoft Graph (mail)
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=

# ── Invoice Summarizer ───────────────────────────────────────
# URL of the Invoice Summarizer service (iframe embed)
NEXT_PUBLIC_INVOICE_SERVICE_URL=

# ── AI — Anthropic Claude ────────────────────────────────────
ANTHROPIC_API_KEY=
AI_MODEL_COMPLEX=claude-opus-4-8
AI_MODEL_FAST=claude-haiku-4-5

# ── Companies House ──────────────────────────────────────────
COMPANIES_HOUSE_API_KEY=

# ── Accounting integrations ──────────────────────────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=

# ── KYC/AML & E-sign ─────────────────────────────────────────
KYC_PROVIDER=amiqus
KYC_API_KEY=
ESIGN_PROVIDER=dropbox_sign
ESIGN_API_KEY=

# ── Document AI / OCR ────────────────────────────────────────
AZURE_DOCAI_ENDPOINT=
AZURE_DOCAI_KEY=

# ── Observability ─────────────────────────────────────────────
SENTRY_DSN=

# ── Webhook signing ──────────────────────────────────────────
WEBHOOK_SIGNING_SECRET=change-me-in-prod
