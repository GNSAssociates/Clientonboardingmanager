{
  "framework": "nextjs",
  "outputDirectory": ".next",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile --prod=false",
  "buildCommand": "pnpm build",
  "crons": [
    {
      "path": "/api/clearance/auto-chase",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/documents/auto-chase",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/onboarding/scheduled-send",
      "schedule": "*/5 * * * *"
    }
  ]
}
